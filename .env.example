# Required
WCLAW_TELEGRAM_TOKEN=your_bot_token_here
WCLAW_ADMIN_CHAT_ID=123456789

# Optional: additional allowed chat IDs (comma-separated)
# WCLAW_ALLOWED_CHAT_IDS=111,222,333

# Claude CLI
# WCLAW_MODEL=sonnet
# WCLAW_FALLBACK_MODEL=haiku
# WCLAW_MAX_BUDGET=10.0
# WCLAW_WORKING_DIR=/workspace
# WCLAW_PERMISSION_MODE=dangerously_skip
# WCLAW_SYSTEM_PROMPT=You are a helpful assistant.
# WCLAW_TIMEOUT=300
# WCLAW_RATE_LIMIT_RETRY=30

# Heartbeat
# WCLAW_HEARTBEAT_ENABLED=true
# WCLAW_HEARTBEAT_INTERVAL=900
# WCLAW_HEARTBEAT_PROMPT=Review any pending context...
# WCLAW_HEARTBEAT_NOTIFY=true

# Voice transcription (requires whisper-cpp binary and model)
# WCLAW_VOICE_ENABLED=true
# WCLAW_WHISPER_MODEL=/path/to/ggml-base.en.bin

# Logging
RUST_LOG=info

# Docker deployment
# Run `wclaw setup` on the host first to authenticate with Claude and configure
# Telegram. docker-compose.yml mounts ~/.claude (OAuth tokens) and ~/.wclaw
# (config + data) from the host into the container.
